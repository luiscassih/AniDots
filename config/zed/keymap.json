// Zed keymap
//
// For information on binding keys, see the Zed
// documentation: https://zed.dev/docs/key-bindings
//
// To see the default key bindings run `zed: open default keymap`
// from the command palette.
[
  {
    "context": "Workspace",
    "bindings": {
      // "shift shift": "file_finder::Toggle"
      // "space space": "file_finder::Toggle",
    },
  },
  {
    "context": "Editor && !menu",
    "bindings": {
      "ctrl-f": "buffer_search::Deploy",
      "ctrl-l": "workspace::ToggleRightDock",
      "ctrl-g": "git_panel::Toggle",
      "ctrl-b": "project_panel::Toggle",
    },
  },
  {
    "context": "Editor && vim_mode == normal && !menu",
    "bindings": {
      "space space": "file_finder::Toggle",
      "space l g": [
        "task::Spawn",
        { "task_name": "Lazygit", "reveal_target": "center" },
      ],
      "ctrl-d": ["workspace::SendKeystrokes", "8 j"],
      "ctrl-u": ["workspace::SendKeystrokes", "8 k"],
      "ctrl-t": "terminal_panel::Toggle",
      "ctrl-s": "projects::OpenRecent",
      "ctrl-S": "project_symbols::Toggle",
      // "w": "vim::NextWordStart",
      // "w": ["action::Sequence", ["vim::NextWordStart", "vim::Word"]],
    },
  },
  {
    "context": "Terminal",
    "bindings": {
      "ctrl-t": "terminal_panel::Toggle",
    },
  },
  {
    "context": "VimControl && !menu",
    "unbind": {
      "ctrl-f": "vim::PageDown",
      "ctrl-b": "vim::PageUp",
    },
  },
  {
    "context": "vim_mode == literal",
    "unbind": {
      "ctrl-f": ["vim::Literal", ["ctrl-f", "\u0006"]],
      "ctrl-b": ["vim::Literal", ["ctrl-b", "\u0002"]],
    },
  },
  {
    "context": "SkillCreator > Editor",
    "unbind": {
      "ctrl-w": "workspace::CloseWindow",
    },
  },
  {
    "context": "SkillCreator",
    "unbind": {
      "ctrl-w": "workspace::CloseWindow",
    },
  },
  {
    "context": "SettingsWindow",
    "unbind": {
      "ctrl-w": "workspace::CloseWindow",
    },
  },
  {
    "context": "Workspace",
    "unbind": {
      "ctrl-w": "workspace::CloseActiveDock",
    },
    "bindings": {
      "ctrl-g": "git_panel::Toggle",
      "ctrl-b": "project_panel::Toggle",
    },
  },
  {
    "context": "Pane",
    "unbind": {
      "ctrl-w": [
        "pane::CloseActiveItem",
        {
          "close_pinned": false,
        },
      ],
    },
  },
  {
    "context": "VimControl && !menu",
    "bindings": {},
    // "unbind": {
    //   "w": "vim::NextWordStart"
    // }
  },
]
